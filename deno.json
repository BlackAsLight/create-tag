{
  "name": "@doctor/create-tag",
  "version": "0.3.1",
  "exports": "./mod.ts",
  "publish": {
    "exclude": [
      ".*"
    ]
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom"
    ]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 128,
    "indentWidth": 2
  },
  "tasks": {
    "ok": "deno fmt && deno lint && deno check *.ts"
  }
}
